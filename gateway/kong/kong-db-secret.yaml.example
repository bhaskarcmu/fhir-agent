# Kong database credentials — Neon PostgreSQL (kongdb)
#
# DO NOT COMMIT THE REAL VERSION OF THIS FILE.
# Copy this file to kong-db-secret.yaml, fill in the values, apply it
# to your cluster, then delete the local copy:
#
#   cp kong-db-secret.yaml.example kong-db-secret.yaml
#   # edit kong-db-secret.yaml with real base64-encoded values
#   kubectl apply -f kong-db-secret.yaml -n kong
#   rm kong-db-secret.yaml
#
# To base64-encode a value:
#   echo -n "your-value" | base64
#
# The Neon connection string has this shape:
#   postgresql://USER:PASSWORD@HOST/kongdb?sslmode=require
# Split it into the individual fields below.

apiVersion: v1
kind: Secret
metadata:
  name: kong-db-secret
  namespace: kong
type: Opaque
data:
  # echo -n "ep-restless-resonance-amqcyrmq-pooler.c-5.us-east-1.aws.neon.tech" | base64
  pg_host: <base64-encoded-neon-host>

  # echo -n "5432" | base64
  pg_port: <base64-encoded-port>

  # echo -n "kongdb" | base64
  pg_database: <base64-encoded-database-name>

  # echo -n "neondb_owner" | base64
  pg_user: <base64-encoded-username>

  # echo -n "your-neon-password" | base64
  pg_password: <base64-encoded-password>
