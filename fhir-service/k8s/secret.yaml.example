# Template for the fhir-service Kubernetes Secret.
#
# DO NOT commit the real secret.yaml — it is gitignored.
# The real file contains the Neon fhirdb password embedded in the JDBC URL.
#
# ─────────────────────────────────────────────────────────────────────────
# RECOMMENDED: create the Secret imperatively (never touches the filesystem)
# ─────────────────────────────────────────────────────────────────────────
#
#   kubectl create secret generic fhir-service-secret \
#     --namespace fhir \
#     --from-literal=SPRING_DATASOURCE_URL="jdbc:postgresql://HOST/DB?user=USER&password=PASS&sslmode=require"
#
# Get your Neon JDBC URL:
#   Neon Dashboard → select project → Connection string → JDBC format
#
# ─────────────────────────────────────────────────────────────────────────
# ALTERNATIVE: apply this file (fill in the base64 value first)
# ─────────────────────────────────────────────────────────────────────────
#
# 1. Base64-encode your JDBC URL (no newline):
#      echo -n "jdbc:postgresql://HOST/DB?user=USER&password=PASS&sslmode=require" | base64
#
# 2. Replace <base64-encoded-jdbc-url> below with the output.
#
# 3. Copy this file, fill it in, apply it, then delete the copy:
#      cp secret.yaml.example /tmp/fhir-service-secret.yaml
#      # edit /tmp/fhir-service-secret.yaml
#      kubectl apply -f /tmp/fhir-service-secret.yaml -n fhir
#      rm /tmp/fhir-service-secret.yaml
#
# ─────────────────────────────────────────────────────────────────────────
apiVersion: v1
kind: Secret
metadata:
  name: fhir-service-secret
  namespace: fhir
type: Opaque
data:
  # base64-encoded JDBC URL:
  #   jdbc:postgresql://HOST/DB?user=USER&password=PASS&sslmode=require
  SPRING_DATASOURCE_URL: <base64-encoded-jdbc-url>
