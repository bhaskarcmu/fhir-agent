{
  "name": "Agentic Healthcare Platform (minimal test)",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "vscjava.vscode-java-pack",
        "vmware.vscode-spring-boot",
        "ms-python.python",
        "github.copilot",
        "github.copilot-chat",
        "continue.continue",
        "rooveterinaryinc.roo-cline",
        "redhat.vscode-yaml"
      ]
    }
  },
  "remoteUser": "vscode",
  "containerEnv": {
    "CLAUDE_API_KEY": "${localEnv:CLAUDE_API_KEY}",
    "COPILOT_TOKEN": "${localEnv:COPILOT_TOKEN}",
    "ANTHROPIC_API_KEY": "${localEnv:CLAUDE_API_KEY}"
  }
}
