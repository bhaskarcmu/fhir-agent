# Copy to .env and fill in your values. Never commit .env.
#   cp .env.example .env

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Required for the MCP agent.
ANTHROPIC_API_KEY=sk-ant-...

# ── FHIR server (Kong gateway) ────────────────────────────────────────────────
# Both the triage service and the MCP agent are clinical-hat consumers.
# They ALWAYS authenticate through Kong — never talk to HAPI directly.
#
# FHIR_API_KEY is required. Get one by running:
#   kubectl port-forward svc/kong-kong-admin 8101:8001 -n kong
#   KONG_ADMIN_URL=http://localhost:8101 bash gateway/tools/create-key.sh <name>
#
# GCP (production / demo against live data):
FHIR_GATEWAY_URL=http://localhost:8000/fhir   # kubectl port-forward svc/kong-kong-proxy 8000:80 -n kong
FHIR_API_KEY=your-kong-api-key                # from create-key.sh

# Local HAPI only (platform engineers / integration tests — Hat 1):
# FHIR_GATEWAY_URL=http://localhost:8080/fhir
# FHIR_API_KEY=                               # HAPI has no auth — leave blank only for Hat 1 work

# ── Triage service ────────────────────────────────────────────────────────────
# Default matches Docker Compose port mapping.
TRIAGE_SERVICE_URL=http://localhost:8001

# ── Neon PostgreSQL (production only) ─────────────────────────────────────────
# Used by HAPI FHIR JPA in production. Not needed for local Docker Compose.
# DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/fhirdb?sslmode=require
