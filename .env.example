# Copy to .env and fill in your values. Never commit .env.
#   cp .env.example .env

# ── Anthropic ─────────────────────────────────────────────────────────────────
# Required for the MCP agent.
ANTHROPIC_API_KEY=sk-ant-...

# ── FHIR server ───────────────────────────────────────────────────────────────
# Local HAPI FHIR (Docker Compose default):
FHIR_GATEWAY_URL=http://localhost:8080/fhir

# Production (Kong gateway):
# FHIR_GATEWAY_URL=https://your-kong-gateway.example.com/fhir
# FHIR_API_KEY=your-kong-api-key

# ── Triage service ────────────────────────────────────────────────────────────
# Default matches Docker Compose port mapping.
TRIAGE_SERVICE_URL=http://localhost:8001

# ── Neon PostgreSQL (production only) ─────────────────────────────────────────
# Used by HAPI FHIR JPA in production. Not needed for local Docker Compose.
# DATABASE_URL=postgresql://user:password@ep-xxx.us-east-2.aws.neon.tech/fhirdb?sslmode=require
